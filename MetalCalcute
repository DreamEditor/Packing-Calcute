    function numberFormat(num, digits = 3){
      return Number(num || 0).toLocaleString("en-US", {
        minimumFractionDigits: digits,
        maximumFractionDigits: digits
      });
    }

    function moneyFormat(num){
      return Number(num || 0).toLocaleString("en-US", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });
    }

    function escapeHtml(str){
      return String(str)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function initSelectors(){
      Object.entries(steelTypes).forEach(([key, item]) => {
        const opt = document.createElement("option");
        opt.value = key;
        opt.textContent = item.label;
        steelTypeEl.appendChild(opt);
      });

      Object.entries(materialPresets).forEach(([key, item]) => {
        const opt = document.createElement("option");
        opt.value = key;
        opt.textContent = `${item.label}（${item.density} kg/m³）`;
        materialPresetEl.appendChild(opt);
      });

      steelTypeEl.value = "roundBar";
      materialPresetEl.value = "carbonSteel";
      densityEl.value = materialPresets.carbonSteel.density;
    }

    function renderField(field){
      if (field.type === "profile"){
        const table = profileTables[field.table] || [];
        const options = table.map((row, idx) =>
          `<option value="${escapeHtml(row.label)}" data-unit="${row.unitWeight}" data-details="${escapeHtml(row.details)}" ${idx === 0 ? "selected" : ""}>${escapeHtml(row.label)}（${row.unitWeight} kg/m）</option>`
        ).join("");

        return `
          <div class="field">
            <label for="${field.id}">${field.label}</label>
            <select id="${field.id}" data-field-type="profile" data-table="${field.table}">
              ${options}
            </select>
            <small>选规格后会自动带出理论单位重，下面仍可手动修改。</small>
          </div>
        `;
      }

      if (field.type === "select"){
        const options = (field.options || []).map(opt =>
          `<option value="${escapeHtml(opt.value)}" ${String(field.value) === String(opt.value) ? "selected" : ""}>${escapeHtml(opt.text)}</option>`
        ).join("");
        return `
          <div class="field">
            <label for="${field.id}">${field.label}</label>
            <select id="${field.id}">
              ${options}
            </select>
          </div>
        `;
      }

      return `
        <div class="field">
          <label for="${field.id}">${field.label}</label>
          <input
            id="${field.id}"
            type="${field.type || "number"}"
            step="${field.step || "any"}"
            min="${field.min || ""}"
            value="${field.value ?? ""}"
          />
        </div>
      `;
    }

    function renderDynamicForm(){
      const typeKey = steelTypeEl.value;
      const type = steelTypes[typeKey];
      dynamicFormEl.innerHTML = `
        <div class="inline-note">
          <strong>${type.label}</strong>：${type.desc}
        </div>
        <div class="grid" style="margin-top:14px;">
          ${type.fields.map(renderField).join("")}
        </div>
        <div class="inline-note" id="profileDetailsBox">
          当前类型说明：${type.desc}
        </div>
      `;

      const profileSelect = dynamicFormEl.querySelector('[data-field-type="profile"]');
      if (profileSelect){
        profileSelect.addEventListener("change", syncProfileUnitWeight);
        syncProfileUnitWeight();
      } else {
        const detailBox = document.getElementById("profileDetailsBox");
        if (detailBox){
          detailBox.innerHTML = `当前类型说明：${type.desc}`;
        }
      }
    }

    function syncProfileUnitWeight(){
      const type = steelTypes[steelTypeEl.value];
      const profileSelect = document.getElementById("profileSpec");
      const unitWeightInput = document.getElementById("unitWeight");
      const detailBox = document.getElementById("profileDetailsBox");
      if (!profileSelect || !unitWeightInput) return;

      const selected = profileSelect.options[profileSelect.selectedIndex];
      const unit = selected.dataset.unit;
      const details = selected.dataset.details || type.desc;

      unitWeightInput.value = unit;
      if (detailBox){
        detailBox.innerHTML = `<strong>规格说明：</strong>${details}`;
      }
    }

    function collectValues(){
      const type = steelTypes[steelTypeEl.value];
      const values = {};
      type.fields.forEach(field => {
        const el = document.getElementById(field.id);
        if (!el) return;
        if (field.type === "select" || field.type === "profile") {
          values[field.id] = el.value;
        } else {
          values[field.id] = Number(el.value);
        }
      });
      return values;
    }

    function validateValues(values){
      for (const [key, val] of Object.entries(values)){
        if (typeof val === "number" && (!Number.isFinite(val) || val < 0)){
          throw new Error(`输入项 ${key} 无效，请检查。`);
        }
      }
    }

    function doCalculate(){
      const typeKey = steelTypeEl.value;
      const type = steelTypes[typeKey];
      const density = Number(densityEl.value);
      const pricePerKg = Number(document.getElementById("pricePerKg").value || 0);
      if (!Number.isFinite(density) || density <= 0){
        throw new Error("密度必须大于 0。");
      }
      if (!Number.isFinite(pricePerKg) || pricePerKg < 0){
        throw new Error("单价不能小于 0。");
      }

      const values = collectValues();
      validateValues(values);

      const result = type.calculate(values, density);
      const totalPrice = result.totalWeight * pricePerKg;

      currentResult = {
        typeKey,
        typeLabel: type.label,
        specText: result.specText,
        metaText: result.metaText,
        formula: result.formula,
        values,
        density,
        pricePerKg,
        singleWeight: result.singleWeight,
        totalWeight: result.totalWeight,
        totalPrice
      };

      singleWeightEl.textContent = `${numberFormat(result.singleWeight)} kg`;
      totalWeightEl.textContent = `${numberFormat(result.totalWeight)} kg`;
      totalPriceEl.textContent = `${moneyFormat(totalPrice)} Tk`;
      resultSpecEl.textContent = result.specText;
      resultMetaEl.textContent = result.metaText;
      formulaBoxEl.innerHTML = `
        <strong>计算方式：</strong>${result.formula}<br />
        <strong>当前说明：</strong>${result.metaText}<br />
        <strong>理论金额：</strong> ${moneyFormat(totalPrice)} Tk（单价 ${moneyFormat(pricePerKg)} Tk/kg）
      `;

      return currentResult;
    }

    function renderList(){
      if (!items.length){
        listBodyEl.innerHTML = `<tr><td colspan="9" class="empty">暂无数据，先计算后点击“加入清单”。</td></tr>`;
      } else {
        listBodyEl.innerHTML = items.map((item, index) => `
          <tr>
            <td>${index + 1}</td>
            <td>${escapeHtml(item.typeLabel)}</td>
            <td>${escapeHtml(item.specText)}<br><span style="color:#6b7280;">${escapeHtml(item.metaText)}</span></td>
            <td>${item.qtyDisplay}</td>
            <td>${numberFormat(item.singleWeight)} kg</td>
            <td>${numberFormat(item.totalWeight)} kg</td>
            <td>${moneyFormat(item.pricePerKg)} Tk/kg</td>
            <td>${moneyFormat(item.totalPrice)} Tk</td>
            <td><button class="delete-btn" onclick="removeItem(${index})">删除</button></td>
          </tr>
        `).join("");
      }

      const sumWeight = items.reduce((acc, cur) => acc + cur.totalWeight, 0);
      const sumAmount = items.reduce((acc, cur) => acc + cur.totalPrice, 0);

      document.getElementById("sumItems").textContent = items.length;
      document.getElementById("sumWeight").textContent = `${numberFormat(sumWeight)} kg`;
      document.getElementById("sumAmount").textContent = `${moneyFormat(sumAmount)} Tk`;
    }

    function addToList(){
      const result = currentResult || doCalculate();
      const qtyField = document.getElementById("qty");
      items.push({
        ...result,
        qtyDisplay: qtyField ? qtyField.value : "1"
      });
      renderList();
    }

    function resetCurrent(){
      renderDynamicForm();
      materialPresetEl.value = "carbonSteel";
      densityEl.value = materialPresets.carbonSteel.density;
      document.getElementById("pricePerKg").value = 0;
      currentResult = null;

      singleWeightEl.textContent = "0.000 kg";
      totalWeightEl.textContent = "0.000 kg";
      totalPriceEl.textContent = "0.00 Tk";
      resultSpecEl.textContent = "未计算";
      resultMetaEl.textContent = "等待输入";
      formulaBoxEl.textContent = "选择钢材并输入数据后，这里会显示计算依据。";
    }

    function removeItem(index){
      items.splice(index, 1);
      renderList();
    }

    function clearList(){
      items = [];
      renderList();
    }

    window.removeItem = removeItem;

    materialPresetEl.addEventListener("change", () => {
      const preset = materialPresets[materialPresetEl.value];
      if (preset){
        densityEl.value = preset.density;
      }
    });

    densityEl.addEventListener("input", () => {
      if (materialPresetEl.value !== "custom"){
        materialPresetEl.value = "custom";
      }
    });

    steelTypeEl.addEventListener("change", renderDynamicForm);

    document.getElementById("calcBtn").addEventListener("click", () => {
      try{
        doCalculate();
      } catch (err){
        alert(err.message || "计算失败，请检查输入。");
      }
    });

    document.getElementById("addBtn").addEventListener("click", () => {
      try{
        addToList();
      } catch (err){
        alert(err.message || "加入清单失败，请检查输入。");
      }
    });

    document.getElementById("resetBtn").addEventListener("click", resetCurrent);
    document.getElementById("clearListBtn").addEventListener("click", clearList);

    initSelectors();
    renderDynamicForm();
    renderList();
  </script>
</body>
</html>
