      ],
      channelSteel: [
        { label: "5#", unitWeight: 5.438, details: "槽钢 5#，常用理论单位重 5.438 kg/m" },
        { label: "6.3#", unitWeight: 6.634, details: "槽钢 6.3#，常用理论单位重 6.634 kg/m" },
        { label: "8#", unitWeight: 8.046, details: "槽钢 8#，常用理论单位重 8.046 kg/m" },
        { label: "10#", unitWeight: 10.007, details: "槽钢 10#，常用理论单位重 10.007 kg/m" },
