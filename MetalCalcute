        { label: "14a#", unitWeight: 14.535, details: "槽钢 14a#，常用理论单位重 14.535 kg/m" },
        { label: "16a#", unitWeight: 17.240, details: "槽钢 16a#，常用理论单位重 17.240 kg/m" },
        { label: "18a#", unitWeight: 20.174, details: "槽钢 18a#，常用理论单位重 20.174 kg/m" },
        { label: "20a#", unitWeight: 22.637, details: "槽钢 20a#，常用理论单位重 22.637 kg/m" },
        { label: "25a#", unitWeight: 27.410, details: "槽钢 25a#，常用理论单位重 27.410 kg/m" }
